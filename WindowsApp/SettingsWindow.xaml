<Window x:Class="LeftHandDeviceApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="設定" Height="470" Width="760"
        Icon="app_icon.ico"
        WindowStartupLocation="CenterOwner"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左カラム: 有効ボタン数, 機能枠の並び替え -->
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ボタン数設定 -->
            <materialDesign:Card Grid.Row="0" Margin="0,0,0,15" Padding="16">
                <StackPanel>
                    <TextBlock Text="有効ボタン数" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="ActiveButtonCombo" Width="100" HorizontalAlignment="Left"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              materialDesign:HintAssist.Hint="個数 (1-5)"
                              SelectionChanged="ActiveButtonCombo_SelectionChanged">
                        <ComboBoxItem Content="1" Tag="1"/>
                        <ComboBoxItem Content="2" Tag="2"/>
                        <ComboBoxItem Content="3" Tag="3"/>
                        <ComboBoxItem Content="4" Tag="4"/>
                        <ComboBoxItem Content="5" Tag="5"/>
                    </ComboBox>
                </StackPanel>
            </materialDesign:Card>

            <!-- 機能枠の並び替え -->
            <materialDesign:Card Grid.Row="1" Margin="0,0,0,15" Padding="16" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="機能枠の並び替え" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <ListBox x:Name="ReorderListBox" Grid.Column="0" Margin="0,0,10,0"
                                 Style="{StaticResource MaterialDesignListBox}" VerticalAlignment="Stretch"/>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Content="↑" Margin="0,0,0,8" Style="{StaticResource MaterialDesignOutlinedButton}" Click="MoveUp_Click"/>
                            <Button Content="↓" Style="{StaticResource MaterialDesignOutlinedButton}" Click="MoveDown_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- 右カラム: アプリ情報, テーマ設定, アップデート -->
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- アプリ情報 -->
            <materialDesign:Card Grid.Row="0" Margin="0,0,0,15" Padding="16">
                <StackPanel>
                    <TextBlock Text="アプリケーション情報" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="バージョン:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VersionText" Text="v1.0.0" Margin="0,0,0,5"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- テーマ設定 -->
            <materialDesign:Card Grid.Row="1" Margin="0,0,0,15" Padding="16">
                <StackPanel>
                    <TextBlock Text="テーマ設定" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ThemeSystem" Content="システム" GroupName="Theme" 
                                     Margin="0,0,15,0" Style="{StaticResource MaterialDesignRadioButton}"
                                     Checked="Theme_Changed"/>
                        <RadioButton x:Name="ThemeLight" Content="ライト" GroupName="Theme" 
                                     Margin="0,0,15,0" Style="{StaticResource MaterialDesignRadioButton}"
                                     Checked="Theme_Changed"/>
                        <RadioButton x:Name="ThemeDark" Content="ダーク" GroupName="Theme" 
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Checked="Theme_Changed"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- アップデート -->
            <materialDesign:Card Grid.Row="2" Margin="0,0,0,15" Padding="16" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="アップデート" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="UpdateStatusText" Grid.Column="0" 
                                   Text="アップデートを確認してください" 
                                   VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0"/>
                        <Button x:Name="CheckUpdateButton" Grid.Column="1" 
                                Content="確認" 
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Click="CheckUpdate_Click"/>
                    </Grid>
                    <ProgressBar x:Name="UpdateProgress" Grid.Row="2" Margin="0,10,0,0" 
                                 Visibility="Collapsed" IsIndeterminate="True"/>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- 閉じるボタン -->
        <Button Grid.Row="1" Grid.ColumnSpan="3" Content="閉じる" 
                Style="{StaticResource MaterialDesignOutlinedButton}"
                HorizontalAlignment="Right" Width="100" Margin="0,15,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>
