<Window x:Class="LeftHandDeviceApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="設定" SizeToContent="Height" Width="720"
        Icon="app_icon.ico"
        WindowStartupLocation="CenterOwner"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.Resources>
        <SolidColorBrush x:Key="ToggleOnBg" Color="#2196F3"/>
        <SolidColorBrush x:Key="ToggleOffBg" Color="#BDBDBD"/>
        <SolidColorBrush x:Key="ToggleThumb" Color="White"/>
    </Window.Resources>
    
    <Grid Margin="20,20,20,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- 左カラム: ボタン数, テーマ, 通知音, アプリ情報 -->
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ボタン数設定 -->
            <materialDesign:Card Grid.Row="0" Margin="0,0,0,12" Padding="16">
                <StackPanel>
                    <TextBlock Text="有効ボタン数" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="ActiveButtonCombo" Width="100" HorizontalAlignment="Left"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              materialDesign:HintAssist.Hint="個数 (1-5)"
                              SelectionChanged="ActiveButtonCombo_SelectionChanged">
                        <ComboBoxItem Content="1" Tag="1"/>
                        <ComboBoxItem Content="2" Tag="2"/>
                        <ComboBoxItem Content="3" Tag="3"/>
                        <ComboBoxItem Content="4" Tag="4"/>
                        <ComboBoxItem Content="5" Tag="5"/>
                    </ComboBox>
                </StackPanel>
            </materialDesign:Card>

            <!-- テーマ設定 -->
            <materialDesign:Card Grid.Row="1" Margin="0,0,0,12" Padding="16">
                <StackPanel>
                    <TextBlock Text="テーマ設定" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ThemeSystem" Content="システム" GroupName="Theme" 
                                     Margin="0,0,15,0" Style="{StaticResource MaterialDesignRadioButton}"
                                     Checked="Theme_Changed"/>
                        <RadioButton x:Name="ThemeLight" Content="ライト" GroupName="Theme" 
                                     Margin="0,0,15,0" Style="{StaticResource MaterialDesignRadioButton}"
                                     Checked="Theme_Changed"/>
                        <RadioButton x:Name="ThemeDark" Content="ダーク" GroupName="Theme" 
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Checked="Theme_Changed"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- 連続動作中の通知設定 -->
            <materialDesign:Card Grid.Row="2" Margin="0,0,0,12" Padding="16">
                <StackPanel>
                    <TextBlock Text="連続動作の通知" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="WarningSoundToggle" 
                                  IsChecked="True"
                                  Checked="WarningSoundToggle_Changed"
                                  Unchecked="WarningSoundToggle_Changed"
                                  VerticalAlignment="Center" Margin="0,0,15,0">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border x:Name="ToggleBg" Width="36" Height="20"
                                            CornerRadius="10"
                                            Background="{StaticResource ToggleOffBg}" Cursor="Hand">
                                        <Ellipse x:Name="Thumb" Width="14" Height="14"
                                                 Fill="{StaticResource ToggleThumb}"
                                                 HorizontalAlignment="Left" Margin="3,0,0,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="ToggleBg" Property="Background" Value="{StaticResource ToggleOnBg}"/>
                                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ToggleBg" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>
                        <TextBlock Text="警告音を鳴らす" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- アプリ情報 -->
            <materialDesign:Card Grid.Row="3" Margin="0,0,0,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="アプリケーション情報" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="バージョン:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="VersionText" Text="v1.0.0" Margin="0,0,0,5"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- 右カラム: 並び替え, アップデート -->
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 並び替え枠は高さ固定に合わせる -->
                <RowDefinition Height="*"/> <!-- アップデート枠が残りのスペースを完全に埋める -->
            </Grid.RowDefinitions>

            <!-- 機能枠の並び替え -->
            <materialDesign:Card Grid.Row="0" Margin="0,0,0,12" Padding="16" VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="機能枠の並び替え" FontSize="15" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Grid.Row="1" Height="202" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" Background="{DynamicResource MaterialDesignPaper}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid x:Name="ReorderListGrid" VerticalAlignment="Top"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </materialDesign:Card>

            <!-- アップデート -->
            <!-- VerticalAlignment="Stretch" にすることで、左カラムの高さと必ず底辺が一致します -->
            <!-- Margin-Topをマイナスにして枠全体を少し上に引き上げ、右カラムの合計高さを縮小させます -->
            <materialDesign:Card Grid.Row="1" Margin="0,-4,0,0" VerticalAlignment="Stretch">
                <Grid>
                    <!-- パディングを内側のGridに移し（GridはMarginで代用）、プログレスバーがレイアウトに干渉しないようにします -->
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/> <!-- ここが自動的に伸縮し、タイトルと内容の隙間を埋めて高さを揃える -->
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="アップデート" FontSize="15" FontWeight="Bold" Margin="0,0,0,0"/> 
                        
                        <!-- 行1（*指定）が自動で広がり、下のコンテンツを押し下げます -->
                        
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="UpdateStatusText"
                                       Text="確認中..." 
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" x:Name="CheckUpdateButton"
                                    Content="確認" 
                                    Padding="12,4"
                                    FontSize="12"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Click="CheckUpdate_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="materialDesign:ButtonProgressAssist.IsIndicatorVisible" Value="False"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="3" x:Name="LastCheckTimeText"
                                   Text="" FontSize="11" Foreground="Gray" 
                                   Margin="0,-4,0,0"/>
                    </Grid>

                    <ProgressBar x:Name="UpdateProgress" VerticalAlignment="Bottom" Height="4" Margin="0" 
                                 Visibility="Collapsed" IsIndeterminate="True"/>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- 閉じるボタン -->
        <Button Grid.Row="1" Grid.ColumnSpan="3" Content="閉じる" 
                Style="{StaticResource MaterialDesignOutlinedButton}"
                HorizontalAlignment="Right" Width="100" Margin="0,15,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>

